{
  "manifest_version": 3,
  "name": "Cyber Cookie",
  "version": "1.3.5",
  "description": "CyberCookie, an extension reinventing Cookie Clicker. Made With 💗 by Endermythex",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "cookie_icon.png",
      "48": "cookie_icon.png",
      "128": "cookie_icon.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  }
}