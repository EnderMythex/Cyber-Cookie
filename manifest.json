{
  "manifest_version": 3,
  "name": "Cyber Cookie",
  "version": "1.3.5",
  "description": "CyberCookie, an extension reinventing Cookie Clicker. Made With 💗 by Endermythex",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "./pictures/cookie.png",
      "48": "./pictures/cookie.png",
      "128": "./pictures/cookie.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  }
}